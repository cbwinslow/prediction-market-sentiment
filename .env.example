# Prediction Market Sentiment Analyzer Configuration
# Copy this file to .env and adjust as needed

# Optional: Proxy settings if needed
# HTTP_PROXY=
# HTTPS_PROXY=

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Default output directory for exports
OUTPUT_DIR=output

# Optional: Arbitrage detection defaults
DEFAULT_MIN_SPREAD=0.02
DEFAULT_MIN_VOLUME=100.0
DEFAULT_MIN_CONFIDENCE=0.3

# Optional: API rate limiting (requests per second)
# KALSHI_RATE_LIMIT=10
# POLYMARKET_RATE_LIMIT=10
